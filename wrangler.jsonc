{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bread-cloudflare-probe",
  "main": "worker.js",
  "compatibility_date": "2026-06-29",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bread-cloudflare-probe-db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  }
}
